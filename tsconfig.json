{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@gaia-kernel/sdk": ["../GAIA/libs/sdk-ts"]
    }
  },
  "include": ["pkg/**/*", "agents/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
